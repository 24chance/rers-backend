generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  APPLICANT
  REVIEWER
  IRB_ADMIN
  RNEC_ADMIN
  FINANCE_OFFICER
  CHAIRPERSON
  SYSTEM_ADMIN
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  SCREENING
  PAYMENT_PENDING
  PAYMENT_VERIFIED
  UNDER_REVIEW
  QUERY_RAISED
  RESPONSE_RECEIVED
  DECISION_PENDING
  APPROVED
  CONDITIONALLY_APPROVED
  REJECTED
  AMENDMENT_PENDING
  MONITORING_ACTIVE
  CLOSED
}

enum ApplicationType {
  FULL_BOARD
  EXPEDITED
  EXEMPT
}

enum ReviewRecommendation {
  APPROVE
  APPROVE_WITH_CONDITIONS
  REJECT
  DEFER
  ABSTAIN
}

enum DecisionType {
  APPROVED
  CONDITIONALLY_APPROVED
  REJECTED
  DEFERRED
}

enum DocumentType {
  PROTOCOL
  CONSENT_FORM
  QUESTIONNAIRE
  BUDGET
  CV
  ETHICS_APPROVAL
  SUPPORTING_DOCUMENT
  AMENDMENT_DOCUMENT
  RENEWAL_DOCUMENT
  PROGRESS_REPORT_DOCUMENT
  AE_REPORT_DOCUMENT
  DEVIATION_DOCUMENT
  CLOSURE_DOCUMENT
  OTHER
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
  REFUNDED
}

enum MonitoringType {
  AMENDMENT
  RENEWAL
  PROGRESS_REPORT
  ADVERSE_EVENT
  PROTOCOL_DEVIATION
  CLOSURE_REPORT
}

enum NotificationType {
  APPLICATION_SUBMITTED
  QUERY_RAISED
  QUERY_RESPONSE
  PAYMENT_PENDING
  PAYMENT_VERIFIED
  REVIEWER_ASSIGNED
  DECISION_ISSUED
  CERTIFICATE_AVAILABLE
  MONITORING_REMINDER
  GENERAL
}

enum MonitoringStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum SeverityLevel {
  MILD
  MODERATE
  SEVERE
  LIFE_THREATENING
  FATAL
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  type      String
  logoUrl   String?
  address   String?
  phone     String?
  email     String?
  isActive  Boolean  @default(true)
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  applications Application[]
  institutions Institution[]
  auditLogs    AuditLog[]

  @@map("tenants")
}

model Role {
  id          String   @id @default(uuid())
  name        UserRole @unique
  description String?
  createdAt   DateTime @default(now())

  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  resource    String
  action      String
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String
  firstName      String
  lastName       String
  phone          String?
  isActive       Boolean   @default(true)
  isVerified     Boolean   @default(false)
  otpCode        String?
  otpExpiresAt   DateTime?
  resetToken     String?
  resetExpiresAt DateTime?
  lastLoginAt    DateTime?
  tenantId       String?
  roleId         String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant           Tenant?           @relation(fields: [tenantId], references: [id])
  role             Role              @relation(fields: [roleId], references: [id])
  applicantProfile ApplicantProfile?
  applications     Application[]
  reviewAssignments ReviewAssignment[]
  reviews          Review[]
  notifications    Notification[]
  auditLogs        AuditLog[]

  @@map("users")
}

model ApplicantProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  institution    String?
  department     String?
  position       String?
  qualifications String?
  orcidId        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("applicant_profiles")
}

model Institution {
  id       String  @id @default(uuid())
  name     String
  code     String  @unique
  type     String
  address  String?
  phone    String?
  email    String?
  tenantId String
  isActive Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  applications Application[]

  @@map("institutions")
}

// ─── Application ──────────────────────────────────────────────────────────────

model Application {
  id                    String            @id @default(uuid())
  referenceNumber       String?           @unique
  title                 String
  type                  ApplicationType
  status                ApplicationStatus @default(DRAFT)
  tenantId              String
  applicantId           String
  destinationId         String?
  principalInvestigator String?
  coInvestigators       String[]
  studyDuration         String?
  studyStartDate        DateTime?
  studyEndDate          DateTime?
  population            String?
  sampleSize            Int?
  methodology           String?
  fundingSource         String?
  budget                Decimal?
  ethicsStatement       String?
  consentDescription    String?
  formData              Json?
  submittedAt           DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  applicant           User                 @relation(fields: [applicantId], references: [id])
  destination         Institution?         @relation(fields: [destinationId], references: [id])
  documents           ApplicationDocument[]
  workflowTransitions WorkflowTransition[]
  reviewAssignments   ReviewAssignment[]
  reviews             Review[]
  decisions           Decision[]
  certificates        Certificate[]
  invoices            Invoice[]
  queries             Query[]
  amendments          Amendment[]
  renewals            Renewal[]
  progressReports     ProgressReport[]
  adverseEvents       AdverseEvent[]
  protocolDeviations  ProtocolDeviation[]
  closureReports      ClosureReport[]

  @@map("applications")
}

model ApplicationDocument {
  id            String       @id @default(uuid())
  applicationId String
  fileName      String
  originalName  String
  mimeType      String
  size          Int
  path          String
  documentType  DocumentType
  version       Int          @default(1)
  uploadedById  String?
  createdAt     DateTime     @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("application_documents")
}

// ─── Workflow ─────────────────────────────────────────────────────────────────

model WorkflowTransition {
  id            String             @id @default(uuid())
  applicationId String
  fromStatus    ApplicationStatus?
  toStatus      ApplicationStatus
  actorId       String?
  reason        String?
  notes         String?
  createdAt     DateTime           @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("workflow_transitions")
}

// ─── Review ───────────────────────────────────────────────────────────────────

model ReviewAssignment {
  id               String   @id @default(uuid())
  applicationId    String
  reviewerId       String
  assignedById     String?
  conflictDeclared Boolean  @default(false)
  conflictReason   String?
  isActive         Boolean  @default(true)
  dueDate          DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  reviewer    User        @relation(fields: [reviewerId], references: [id])

  @@map("review_assignments")
}

model Review {
  id             String                @id @default(uuid())
  applicationId  String
  reviewerId     String
  comments       String?
  recommendation ReviewRecommendation?
  conditions     String?
  isComplete     Boolean               @default(false)
  completedAt    DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  reviewer    User        @relation(fields: [reviewerId], references: [id])

  @@map("reviews")
}

// ─── Queries ──────────────────────────────────────────────────────────────────

model Query {
  id            String    @id @default(uuid())
  applicationId String
  raisedById    String?
  question      String
  isResolved    Boolean   @default(false)
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())

  application Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  responses   QueryResponse[]

  @@map("queries")
}

model QueryResponse {
  id          String   @id @default(uuid())
  queryId     String
  responderId String?
  response    String
  createdAt   DateTime @default(now())

  query Query @relation(fields: [queryId], references: [id], onDelete: Cascade)

  @@map("query_responses")
}

// ─── Decision ─────────────────────────────────────────────────────────────────

model Decision {
  id            String       @id @default(uuid())
  applicationId String
  type          DecisionType
  conditions    String?
  rationale     String?
  decidedById   String?
  letterPath    String?
  createdAt     DateTime     @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  certificate Certificate?

  @@map("decisions")
}

// ─── Certificate ──────────────────────────────────────────────────────────────

model Certificate {
  id                String    @id @default(uuid())
  applicationId     String
  decisionId        String    @unique
  certificateNumber String    @unique
  verificationToken String    @unique @default(uuid())
  pdfPath           String?
  issuedAt          DateTime  @default(now())
  expiresAt         DateTime?

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  decision    Decision    @relation(fields: [decisionId], references: [id])

  @@map("certificates")
}

// ─── Payments ─────────────────────────────────────────────────────────────────

model Invoice {
  id            String        @id @default(uuid())
  applicationId String
  amount        Decimal
  currency      String        @default("KES")
  description   String?
  dueDate       DateTime?
  status        PaymentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  payments    Payment[]

  @@map("invoices")
}

model Payment {
  id              String        @id @default(uuid())
  invoiceId       String
  amount          Decimal
  method          String?
  referenceNumber String?
  status          PaymentStatus @default(PENDING)
  verifiedById    String?
  verifiedAt      DateTime?
  notes           String?
  createdAt       DateTime      @default(now())

  invoice  Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  receipts Receipt[]

  @@map("payments")
}

model Receipt {
  id            String   @id @default(uuid())
  paymentId     String
  receiptNumber String   @unique
  amount        Decimal
  issuedAt      DateTime @default(now())
  pdfPath       String?

  payment Payment @relation(fields: [paymentId], references: [id])

  @@map("receipts")
}

// ─── Monitoring ───────────────────────────────────────────────────────────────

model Amendment {
  id            String           @id @default(uuid())
  applicationId String
  title         String
  description   String
  reason        String
  status        MonitoringStatus @default(DRAFT)
  submittedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("amendments")
}

model Renewal {
  id              String           @id @default(uuid())
  applicationId   String
  extensionPeriod String?
  justification   String
  status          MonitoringStatus @default(DRAFT)
  submittedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("renewals")
}

model ProgressReport {
  id                   String           @id @default(uuid())
  applicationId        String
  reportPeriod         String
  summary              String
  participantsEnrolled Int?
  findings             String?
  status               MonitoringStatus @default(DRAFT)
  submittedAt          DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("progress_reports")
}

model AdverseEvent {
  id                   String           @id @default(uuid())
  applicationId        String
  eventDate            DateTime
  description          String
  severity             SeverityLevel
  affectedParticipants Int?
  actionTaken          String?
  status               MonitoringStatus @default(DRAFT)
  submittedAt          DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("adverse_events")
}

model ProtocolDeviation {
  id               String           @id @default(uuid())
  applicationId    String
  deviationDate    DateTime
  description      String
  impact           String?
  correctiveAction String?
  status           MonitoringStatus @default(DRAFT)
  submittedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("protocol_deviations")
}

model ClosureReport {
  id            String           @id @default(uuid())
  applicationId String
  closureDate   DateTime
  description   String
  totalEnrolled Int?
  findings      String?
  status        MonitoringStatus @default(DRAFT)
  submittedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("closure_reports")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(uuid())
  actorId      String?
  action       String
  targetEntity String
  targetId     String
  tenantId     String?
  metadata     Json?
  ipAddress    String?
  createdAt    DateTime @default(now())

  actor  User?   @relation(fields: [actorId], references: [id])
  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@map("audit_logs")
}
